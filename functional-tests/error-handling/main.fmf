summary: Test MCP server error handling with invalid inputs and failures
description: |
    Tests graceful error responses for bad UUIDs, non-existent agents,
    non-existent policies, verifier log filters, and partial service
    outages (verifier down while registrar is up).
contact: Marek Safarik <msafarik@redhat.com>
component:
  - keylime-mcp
test: ./test.sh
framework: beakerlib
require:
  - type: library
    url: https://github.com/RedHat-SP-Security/keylime-tests
    ref: main
    name: /Library/test-helpers
  - golang
  - jq
recommend:
  - keylime
  - python3-tomli
duration: 10m
enabled: true
