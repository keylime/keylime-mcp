summary: Start keylime services for MCP functional tests
description: |
    Configures and starts keylime services (verifier, registrar, agent)
    with TPM emulator. Must run before all MCP test scripts.
contact: Marek Safarik <msafarik@redhat.com>
component:
  - keylime-mcp
test: ./test.sh
framework: beakerlib
require:
  - type: library
    url: https://github.com/RedHat-SP-Security/keylime-tests
    ref: main
    name: /Library/test-helpers
recommend:
  - keylime
  - python3-tomli
duration: 10m
enabled: true
