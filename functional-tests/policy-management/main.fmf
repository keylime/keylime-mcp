summary: Test runtime and measured boot policy CRUD via MCP tools
description: |
    Tests Import, List, Get, Update, and Delete operations
    for both runtime and measured boot policies through
    the MCP server tool interface.
contact: Marek Safarik <msafarik@redhat.com>
component:
  - keylime-mcp
test: ./test.sh
framework: beakerlib
require:
  - type: library
    url: https://github.com/RedHat-SP-Security/keylime-tests
    ref: main
    name: /Library/test-helpers
  - golang
  - jq
recommend:
  - keylime
  - python3-tomli
duration: 10m
enabled: true
